NODE_ENV=production
PORT=4000
BACKEND_PUBLIC_URL=https://your-backend-domain.com
CORS_ORIGIN=https://your-frontend.vercel.app
STORAGE_DRIVER=spaces
DATABASE_URL=postgresql://user:password@host:5432/database
DO_SPACES_ENDPOINT=https://your-region.digitaloceanspaces.com
DO_SPACES_REGION=your-region
DO_SPACES_KEY=your-spaces-key
DO_SPACES_SECRET=your-spaces-secret
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_PUBLIC_BASE_URL=https://your-bucket-name.your-region.digitaloceanspaces.com
UPLOAD_URL_EXPIRES_SECONDS=900
READ_URL_EXPIRES_SECONDS=300
MAX_UPLOAD_SIZE_MB=200
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
UPLOAD_RATE_LIMIT_MAX_REQUESTS=20
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_SECONDS=3600
AUTH_MODE=jwt
