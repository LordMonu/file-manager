NODE_ENV=production
PORT=4000
BACKEND_PUBLIC_URL=https://staging-api.your-domain.com
CORS_ORIGIN=https://staging-your-app.vercel.app
STORAGE_DRIVER=spaces
DATABASE_URL=postgresql://user:password@host:5432/manage_files_staging
DO_SPACES_ENDPOINT=https://your-region.digitaloceanspaces.com
DO_SPACES_REGION=your-region
DO_SPACES_KEY=your-staging-spaces-key
DO_SPACES_SECRET=your-staging-spaces-secret
DO_SPACES_BUCKET=your-staging-bucket-name
DO_SPACES_PUBLIC_BASE_URL=https://your-staging-bucket-name.your-region.digitaloceanspaces.com
UPLOAD_URL_EXPIRES_SECONDS=900
READ_URL_EXPIRES_SECONDS=300
MAX_UPLOAD_SIZE_MB=200
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
UPLOAD_RATE_LIMIT_MAX_REQUESTS=20
JWT_SECRET=replace-with-staging-jwt-secret
JWT_EXPIRES_SECONDS=3600
AUTH_MODE=jwt
