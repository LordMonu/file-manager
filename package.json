{
  "name": "manage-files",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build:frontend": "npm run build -w frontend",
    "db:migrate": "npm run db:migrate -w backend",
    "test:smoke": "npm run test:smoke -w backend",
    "lint": "echo \"Add linting per app\""
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
